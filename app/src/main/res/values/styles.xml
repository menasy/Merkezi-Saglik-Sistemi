<resources>

    <style name="Widget.MerkeziSaglik.ExposedDropdown" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <style name="Widget.MerkeziSaglik.AutoComplete" parent="Widget.Material3.AutoCompleteTextView.OutlinedBox">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:dropDownWidth">match_parent</item>
        <item name="android:dropDownVerticalOffset">2dp</item>
        <item name="android:popupBackground">@color/surface</item>
    </style>

    <style name="ThemeOverlay.MerkeziSaglik.DateRangePicker" parent="ThemeOverlay.MaterialComponents.MaterialCalendar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/surface</item>
        <item name="materialCalendarStyle">@style/Widget.MerkeziSaglik.MaterialCalendar</item>
    </style>

    <style name="Widget.MerkeziSaglik.MaterialCalendar" parent="Widget.MaterialComponents.MaterialCalendar">
        <item name="rangeFillColor">@android:color/transparent</item>
        <item name="daySelectedStyle">@style/Widget.MerkeziSaglik.MaterialCalendar.Day.Selected</item>
        <item name="dayTodayStyle">@style/Widget.MerkeziSaglik.MaterialCalendar.Day.Today</item>
        <item name="yearSelectedStyle">@style/Widget.MerkeziSaglik.MaterialCalendar.Year.Selected</item>
    </style>

    <style name="Widget.MerkeziSaglik.MaterialCalendar.Day.Selected" parent="Widget.MaterialComponents.MaterialCalendar.Day.Selected">
        <item name="itemFillColor">@android:color/transparent</item>
        <item name="itemStrokeColor">@color/text_primary</item>
        <item name="itemStrokeWidth">1dp</item>
        <item name="itemTextColor">@color/text_primary</item>
    </style>

    <style name="Widget.MerkeziSaglik.MaterialCalendar.Day.Today" parent="Widget.MaterialComponents.MaterialCalendar.Day.Today">
        <item name="itemFillColor">@android:color/transparent</item>
        <item name="itemStrokeColor">@color/text_secondary</item>
        <item name="itemStrokeWidth">1dp</item>
        <item name="itemTextColor">@color/text_primary</item>
    </style>

    <style name="Widget.MerkeziSaglik.MaterialCalendar.Year.Selected" parent="Widget.MaterialComponents.MaterialCalendar.Year.Selected">
        <item name="itemFillColor">@android:color/transparent</item>
        <item name="itemStrokeColor">@color/text_primary</item>
        <item name="itemStrokeWidth">1dp</item>
        <item name="itemTextColor">@color/text_primary</item>
    </style>

    <style name="Widget.MerkeziSaglik.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxStrokeColor">@color/secondary_light</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.MerkeziSaglik.Input</item>
    </style>

    <style name="ShapeAppearanceOverlay.MerkeziSaglik.Input" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">14dp</item>
        <item name="cornerSizeTopRight">14dp</item>
        <item name="cornerSizeBottomLeft">14dp</item>
        <item name="cornerSizeBottomRight">14dp</item>
    </style>

    <style name="Widget.MerkeziSaglik.CommonButton" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:background">@drawable/bg_common_button</item>
        <item name="android:elevation">5dp</item>
        <item name="android:stateListAnimator">@animator/common_button_state_animator</item>
        <item name="android:textColor">@color/common_button_text_selector</item>
    </style>

    <style name="Widget.MerkeziSaglik.Button.Compact" parent="Widget.MerkeziSaglik.CommonButton">
        <item name="android:textSize">14sp</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">9dp</item>
    </style>

    <style name="Widget.MerkeziSaglik.Button.Medium" parent="Widget.MerkeziSaglik.CommonButton">
        <item name="android:textSize">16sp</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:paddingVertical">11dp</item>
    </style>

    <style name="Widget.MerkeziSaglik.Button.Danger" parent="Widget.MerkeziSaglik.Button.Medium">
        <item name="android:backgroundTint">@color/button_danger_background_tint</item>
        <item name="backgroundTint">@color/button_danger_background_tint</item>
        <item name="strokeWidth">0dp</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="Widget.MerkeziSaglik.Button.Large" parent="Widget.MerkeziSaglik.CommonButton">
        <item name="android:textSize">16sp</item>
        <item name="android:paddingHorizontal">22dp</item>
        <item name="android:paddingVertical">12dp</item>
    </style>

    <style name="Widget.MerkeziSaglik.PrimaryButton" parent="Widget.MerkeziSaglik.Button.Large">
        <item name="android:minHeight">46dp</item>
    </style>

    <!-- Action Button Base -->
    <style name="Widget.MerkeziSaglik.Button.Action" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minWidth">@dimen/action_button_min_width</item>
        <item name="android:paddingHorizontal">@dimen/spacing_lg</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:elevation">2dp</item>
    </style>

    <!-- Primary Action Button (Green/Success tones) -->
    <style name="Widget.MerkeziSaglik.Button.Action.Primary" parent="Widget.MerkeziSaglik.Button.Action">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="strokeWidth">0dp</item>
        <item name="rippleColor">@color/primary_dark</item>
    </style>

    <!-- Secondary/Danger Action Button (Red tones) -->
    <style name="Widget.MerkeziSaglik.Button.Action.Secondary" parent="Widget.MerkeziSaglik.Button.Action">
        <item name="backgroundTint">@color/error</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="strokeWidth">0dp</item>
        <item name="rippleColor">@color/error_dark</item>
    </style>

    <!-- Outlined Action Button -->
    <style name="Widget.MerkeziSaglik.Button.Action.Outlined" parent="Widget.MerkeziSaglik.Button.Action">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="strokeColor">@color/divider</item>
    </style>

    <style name="TextAppearance.MerkeziSaglik.BottomMenuLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">9sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/bottom_menu_item_idle_text</item>
    </style>

    <style name="TextAppearance.MerkeziSaglik.PageTitle" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primary_dark</item>
    </style>

    <!-- Chip Styles -->
    <style name="Widget.MerkeziSaglik.Chip.Hour" parent="Widget.Material3.Chip.Filter">
        <item name="android:minHeight">40dp</item>
        <item name="chipMinHeight">40dp</item>
        <item name="android:background">@drawable/bg_chip_hour</item>
        <item name="android:textColor">@color/chip_hour_text_selector</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipCornerRadius">8dp</item>
        <item name="chipStartPadding">14dp</item>
        <item name="chipEndPadding">14dp</item>
        <item name="android:checkable">true</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipIconVisible">false</item>
    </style>

    <style name="Widget.MerkeziSaglik.Chip.Slot" parent="Widget.Material3.Chip.Filter">
        <item name="android:minHeight">36dp</item>
        <item name="chipMinHeight">36dp</item>
        <item name="chipBackgroundColor">@color/chip_slot_bg_selector</item>
        <item name="chipStrokeColor">@color/chip_slot_stroke_selector</item>
        <item name="chipStrokeWidth">1.5dp</item>
        <item name="chipSurfaceColor">@android:color/transparent</item>
        <item name="android:textColor">@color/chip_slot_text_selector</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="chipCornerRadius">8dp</item>
        <item name="chipStartPadding">12dp</item>
        <item name="chipEndPadding">12dp</item>
        <item name="android:checkable">true</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipIconVisible">false</item>
    </style>

</resources>
