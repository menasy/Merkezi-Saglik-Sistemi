<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context="com.menasy.merkezisagliksistemi.ui.patient.appointment.AppointmentConfirmationFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutAppointmentConfirmationTitleRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvAppointmentConfirmationTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Randevu Onayı"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="@color/text_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnBackAppointmentConfirmation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnBackAppointmentConfirmation"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_top_back_button"
            android:contentDescription="Geri"
            android:padding="6dp"
            android:src="@drawable/ic_arrow_back_24"
            android:tint="@color/primary_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvAppointmentConfirmation"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutAppointmentConfirmationTitleRow">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvConfirmationIntro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Randevu bilgilerinizi kontrol ederek onaylayin."
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/text_secondary" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAppointmentConfirmation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/primary_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvConfirmDateLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tarih"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvConfirmDateValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/text_primary"
                        tools:text="12 Mayis 2026, Pazartesi" />

                    <TextView
                        android:id="@+id/tvConfirmTimeLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Saat"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvConfirmTimeValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/text_primary"
                        tools:text="09:20" />

                    <TextView
                        android:id="@+id/tvConfirmHospitalLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Hastane"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvConfirmHospitalValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/text_primary"
                        tools:text="Ankara Sehir Hastanesi" />

                    <TextView
                        android:id="@+id/tvConfirmDoctorLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Doktor"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvConfirmDoctorValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/text_primary"
                        tools:text="Uzm. Dr. Ahmet Demir" />

                    <TextView
                        android:id="@+id/tvConfirmBranchLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Poliklinik"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvConfirmBranchValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/text_primary"
                        tools:text="Kardiyoloji" />

                    <TextView
                        android:id="@+id/tvConfirmPatientLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Randevu Sahibi"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvConfirmPatientValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/text_primary"
                        tools:text="Ayse Yilmaz" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmAppointment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Randevu Onayla" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
