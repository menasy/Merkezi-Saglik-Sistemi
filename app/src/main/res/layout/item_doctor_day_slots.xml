<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/primary_light"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Day Title -->
        <TextView
            android:id="@+id/tvDayTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            tools:text="12 Mayıs Pazartesi" />

        <!-- Day Subtitle -->
        <TextView
            android:id="@+id/tvDaySubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/text_secondary"
            tools:text="8 uygun seans" />

        <!-- Hour Blocks Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Saat Blokları"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/section_label_text"
            android:textStyle="bold" />

        <!-- Hour Blocks ChipGroup -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupHours"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp"
            app:singleSelection="true" />

        <!-- Slot Label -->
        <TextView
            android:id="@+id/tvSlotLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Detaylı Seanslar"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/section_label_text"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- Slot ChipGroup -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupSlots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp"
            app:singleSelection="true"
            tools:visibility="visible" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
