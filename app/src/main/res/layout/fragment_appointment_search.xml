<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context="com.menasy.merkezisagliksistemi.ui.patient.appointment.AppointmentSearchFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvAppointmentSearch"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAppointmentTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Genel Arama"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/primary_dark"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAppointmentSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Tarih ve filtre seçerek uygun randevuyu bulun"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/text_secondary" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDateRange"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/primary_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawablePadding="8dp"
                        android:gravity="center_vertical"
                        android:text="Tarih"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/primary_dark"
                        android:textStyle="bold"
                        app:drawableStartCompat="@android:drawable/ic_menu_my_calendar" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectDateRange"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="Tarih Seçiniz"
                        android:textAllCaps="false"
                        android:textColor="@color/text_primary"
                        app:strokeColor="@color/primary_light" />

                    <TextView
                        android:id="@+id/tvDateRangeHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="En fazla 15 gün seçebilirsiniz."
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/text_secondary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvStartDateValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Başlangıç: -"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tvEndDateValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="Bitiş: -"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFilters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/primary_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Filtreler"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvFilterLegend"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="* zorunlu alan"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/text_secondary" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilCity"
                        style="@style/Widget.MerkeziSaglik.ExposedDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="İl *">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actCity"
                            style="@style/Widget.MerkeziSaglik.AutoComplete"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilDistrict"
                        style="@style/Widget.MerkeziSaglik.ExposedDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="İlçe (Opsiyonel)">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actDistrict"
                            style="@style/Widget.MerkeziSaglik.AutoComplete"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilBranch"
                        style="@style/Widget.MerkeziSaglik.ExposedDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="Poliklinik *">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actBranch"
                            style="@style/Widget.MerkeziSaglik.AutoComplete"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilHospital"
                        style="@style/Widget.MerkeziSaglik.ExposedDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="Hastane (Opsiyonel)">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actHospital"
                            style="@style/Widget.MerkeziSaglik.AutoComplete"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilDoctor"
                        style="@style/Widget.MerkeziSaglik.ExposedDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="Hekim (Opsiyonel)">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actDoctor"
                            style="@style/Widget.MerkeziSaglik.AutoComplete"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSearchAppointments"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:text="Randevu Ara"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:icon="@android:drawable/ic_menu_search" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
