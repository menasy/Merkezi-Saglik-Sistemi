<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context="com.menasy.merkezisagliksistemi.ui.doctor.account.DoctorAccountFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvDoctorAccount"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/page_horizontal_margin"
            android:paddingTop="@dimen/page_vertical_margin"
            android:paddingBottom="32dp">

            <!-- Page Title -->
            <TextView
                android:id="@+id/tvAccountTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/account_title"
                android:textAppearance="@style/TextAppearance.MerkeziSaglik.PageTitle" />

            <!-- Ana Profil Kartı - Tüm bilgileri içerir -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/card_corner_radius_lg"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Profil Header Bölümü -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/spacing_xxl"
                        android:paddingTop="32dp"
                        android:paddingBottom="@dimen/spacing_xxl">

                        <!-- Avatar -->
                        <FrameLayout
                            android:layout_width="88dp"
                            android:layout_height="88dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_doctor_account_avatar" />

                            <ImageView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/doctor_account_doctor_id_label"
                                android:src="@drawable/ic_doctor_24"
                                app:tint="@android:color/white" />
                        </FrameLayout>

                        <!-- Doctor Name -->
                        <TextView
                            android:id="@+id/tvDoctorName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_lg"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:maxLines="2"
                            android:text="-"
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            tools:text="Dr. Ahmet Yılmaz" />

                        <!-- Branch Badge -->
                        <TextView
                            android:id="@+id/tvBranchValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:background="@drawable/bg_doctor_account_role_badge"
                            android:paddingHorizontal="@dimen/spacing_lg"
                            android:paddingVertical="6dp"
                            android:text="@string/doctor_home_branch_unknown"
                            android:textColor="@color/primary_dark"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="Kardiyoloji" />

                    </LinearLayout>

                    <!-- Ayırıcı Çizgi -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="@dimen/spacing_lg"
                        android:background="@color/divider" />

                    <!-- Profil Bilgileri Bölümü -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_xl">

                        <!-- Bölüm Başlığı -->
                        <TextView
                            android:id="@+id/tvInfoSectionTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/doctor_account_info_section_title"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <!-- Hastane Satırı -->
                        <LinearLayout
                            android:id="@+id/layoutHospital"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_lg"
                            android:background="@drawable/bg_doctor_account_info_item"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="@dimen/spacing_lg"
                            android:paddingVertical="@dimen/spacing_md">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp">

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/bg_doctor_account_icon_circle" />

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/doctor_account_hospital_cd"
                                    android:src="@drawable/ic_hospital_24"
                                    app:tint="@color/primary" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_md"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/doctor_account_hospital_cd"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tvHospitalValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:ellipsize="end"
                                    android:maxLines="2"
                                    android:text="@string/doctor_home_hospital_unknown"
                                    android:textColor="@color/text_primary"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    tools:text="Ankara Bilkent Şehir Hastanesi" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Doktor ID Satırı -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:background="@drawable/bg_doctor_account_info_item"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="@dimen/spacing_lg"
                            android:paddingVertical="@dimen/spacing_md">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp">

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/bg_doctor_account_icon_circle" />

                                <ImageView
                                    android:id="@+id/ivDoctorIdIcon"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/doctor_account_doctor_id_label"
                                    android:src="@drawable/ic_account_id_24"
                                    app:tint="@color/primary" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_md"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvDoctorIdLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/doctor_account_doctor_id_label"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tvDoctorIdValue"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:ellipsize="none"
                                    android:maxLines="1"
                                    android:text="-"
                                    android:textColor="@color/text_primary"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    app:autoSizeMaxTextSize="15sp"
                                    app:autoSizeMinTextSize="8sp"
                                    app:autoSizeStepGranularity="1sp"
                                    app:autoSizeTextType="uniform"
                                    tools:text="dr_219678_ortopedi_ve_travmatoloji_1" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Kullanıcı ID Satırı -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:background="@drawable/bg_doctor_account_info_item"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="@dimen/spacing_lg"
                            android:paddingVertical="@dimen/spacing_md">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp">

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/bg_doctor_account_icon_circle" />

                                <ImageView
                                    android:id="@+id/ivUidIcon"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/doctor_account_uid_label"
                                    android:src="@drawable/ic_account_person_24"
                                    app:tint="@color/primary" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_md"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvUidLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/doctor_account_uid_label"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tvUidValue"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:ellipsize="none"
                                    android:maxLines="1"
                                    android:text="-"
                                    android:textColor="@color/text_primary"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    app:autoSizeMaxTextSize="15sp"
                                    app:autoSizeMinTextSize="8sp"
                                    app:autoSizeStepGranularity="1sp"
                                    app:autoSizeTextType="uniform"
                                    tools:text="zxQv8kL1mN2pR4tY6uW7aD9fG3hJ0sX" />
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Ayırıcı Çizgi -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="@dimen/spacing_lg"
                        android:background="@color/divider" />

                    <!-- İstatistik Bölümü -->
                    <LinearLayout
                        android:id="@+id/cardTotalExaminations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_xl">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_doctor_account_stat_circle" />

                            <ImageView
                                android:id="@+id/ivExaminationIcon"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/doctor_account_total_examinations_label"
                                android:src="@drawable/ic_examination_count_24"
                                app:tint="@color/success" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_md"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvExaminationLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/doctor_account_total_examinations_label"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvExaminationSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/doctor_account_total_examinations_subtitle"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvExaminationValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_doctor_account_stat_badge"
                            android:paddingHorizontal="@dimen/spacing_lg"
                            android:paddingVertical="@dimen/spacing_sm"
                            android:text="-"
                            android:textColor="@color/success"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="127" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Çıkış Yap Butonu -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_xl"
                    android:paddingVertical="@dimen/spacing_lg">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_doctor_account_logout_circle" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/account_logout"
                            android:src="@drawable/ic_account_logout_24"
                            app:tint="@color/error" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:text="@string/account_logout"
                        android:textColor="@color/error"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/account_logout"
                        android:rotation="180"
                        android:src="@drawable/ic_arrow_back_24"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
