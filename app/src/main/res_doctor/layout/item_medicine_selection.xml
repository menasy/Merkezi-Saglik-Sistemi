<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    android:background="@drawable/bg_medicine_selection_item"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:minHeight="@dimen/medicine_selection_item_height"
    android:paddingStart="0dp"
    android:paddingTop="@dimen/spacing_md"
    android:paddingEnd="@dimen/spacing_md"
    android:paddingBottom="@dimen/spacing_md">

    <!-- Selection Indicator - full height strip on left -->
    <View
        android:id="@+id/viewSelectionIndicator"
        android:layout_width="4dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_medicine_selection_indicator"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

    <!-- Checkbox -->
    <CheckBox
        android:id="@+id/cbMedicine"
        android:layout_width="@dimen/medicine_selection_checkbox_size"
        android:layout_height="@dimen/medicine_selection_checkbox_size"
        android:layout_marginStart="@dimen/spacing_md"
        android:button="@drawable/selector_checkbox"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/viewSelectionIndicator"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Medicine Name -->
    <TextView
        android:id="@+id/tvMedicineName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_body_lg"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tvMedicineDosage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/cbMedicine"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="Parol 500 mg Tablet" />

    <!-- Dosage Info -->
    <TextView
        android:id="@+id/tvMedicineDosage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_xs"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_size_body_sm"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/cbMedicine"
        app:layout_constraintTop_toBottomOf="@id/tvMedicineName"
        app:layout_goneMarginTop="0dp"
        tools:text="500 mg • Günde 3 kez"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
