<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context="com.menasy.merkezisagliksistemi.ui.doctor.appointments.DoctorAppointmentsFragment">

    <TextView
        android:id="@+id/tvPageTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/page_horizontal_margin"
        android:layout_marginTop="@dimen/page_vertical_margin"
        android:text="@string/doctor_appointments_title"
        android:textAppearance="@style/TextAppearance.MerkeziSaglik.PageTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Simple Tab Layout matching Patient Appointments -->
    <LinearLayout
        android:id="@+id/layoutTabs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/page_horizontal_margin"
        android:layout_marginTop="@dimen/spacing_lg"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPageTitle">

        <!-- Tab: Bekleyen -->
        <LinearLayout
            android:id="@+id/tabPending"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/tvTabPending"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:autoSizeMaxTextSize="13sp"
                app:autoSizeMinTextSize="10sp"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/doctor_appointments_tab_pending"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/indicatorPending"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_tab_indicator"
                android:visibility="visible" />
        </LinearLayout>

        <!-- Tab: Gelecek -->
        <LinearLayout
            android:id="@+id/tabUpcoming"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/tvTabUpcoming"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:autoSizeMaxTextSize="13sp"
                app:autoSizeMinTextSize="10sp"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/doctor_appointments_tab_upcoming"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/indicatorUpcoming"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_tab_indicator"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- Tab: Geçmiş -->
        <LinearLayout
            android:id="@+id/tabPast"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/tvTabPast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:autoSizeMaxTextSize="13sp"
                app:autoSizeMinTextSize="10sp"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/doctor_appointments_tab_past"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/indicatorPast"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_tab_indicator"
                android:visibility="invisible" />
        </LinearLayout>
    </LinearLayout>

    <!-- Section Info Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutSectionInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/page_horizontal_margin"
        android:layout_marginTop="@dimen/spacing_md"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="0dp"
        app:strokeColor="@color/message_card_stroke"
        app:strokeWidth="@dimen/card_stroke_width"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTabs">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <!-- Summary Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvSectionSummary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_body_lg"
                    android:textStyle="bold"
                    tools:text="Bekleyen Randevu Sayısı: 0" />

                <ProgressBar
                    android:id="@+id/progressPrescription"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:indeterminateTint="@color/primary"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Date Filter Row -->
            <LinearLayout
                android:id="@+id/layoutDateFilter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvSelectedDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:drawablePadding="8dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_body"
                    app:drawableStartCompat="@drawable/ic_appointment_calendar"
                    app:drawableTint="@color/text_secondary"
                    tools:text="Seçili Tarih: 31 Mart 2026" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelectDate"
                    style="@style/Widget.MerkeziSaglik.Button.Compact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:maxLines="1"
                    android:text="@string/doctor_appointments_select_date"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAppointments"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/page_vertical_margin"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutSectionInfo"
        tools:listitem="@layout/item_patient_appointment" />

    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/page_horizontal_margin"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutSectionInfo">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:alpha="0.4"
            android:contentDescription="@string/doctor_appointments_empty_icon_cd"
            android:src="@drawable/ic_bottom_appointments_24"
            app:tint="@color/text_secondary" />

        <TextView
            android:id="@+id/tvEmptyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_body_lg"
            tools:text="Bu sekmede randevu yok" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/primary"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
