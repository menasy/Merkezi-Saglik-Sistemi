<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context="com.menasy.merkezisagliksistemi.ui.doctor.examination.DoctorExaminationFragment">

    <ProgressBar
        android:id="@+id/progressLoading"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/primary"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingHorizontal="@dimen/page_horizontal_margin"
        android:paddingTop="@dimen/page_vertical_margin"
        android:paddingBottom="@dimen/spacing_xxl"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title Row -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvExaminationTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/doctor_examination_title"
                    android:textAppearance="@style/TextAppearance.MerkeziSaglik.PageTitle"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/btnBackExamination"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/btnBackExamination"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_top_back_button"
                    android:contentDescription="@string/common_back"
                    android:padding="6dp"
                    android:src="@drawable/ic_arrow_back_24"
                    app:tint="@color/primary_dark"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- SECTION 1: Patient & Appointment Info -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/message_card_stroke"
                app:strokeWidth="@dimen/card_stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Section Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/section_header_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/card_padding"
                        android:paddingVertical="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="@dimen/icon_size_md"
                            android:layout_height="@dimen/icon_size_md"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_appointment_patient_avatar"
                            app:tint="@color/primary_dark" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_md"
                            android:layout_weight="1"
                            android:text="@string/doctor_examination_patient_info_section"
                            android:textColor="@color/primary_dark"
                            android:textSize="@dimen/text_size_body_lg"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Section Content -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <!-- Patient Name -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/doctor_examination_patient_name_label"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_size_body_sm" />

                            <TextView
                                android:id="@+id/tvPatientName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_sm"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:gravity="end"
                                android:maxLines="2"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_size_subtitle"
                                android:textStyle="bold"
                                tools:text="Ayşe Demir" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="@dimen/spacing_md"
                            android:background="@color/section_divider" />

                        <!-- Date -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:drawablePadding="@dimen/spacing_sm"
                                android:text="@string/doctor_examination_date_label"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_size_body_sm"
                                app:drawableStartCompat="@drawable/ic_appointment_calendar"
                                app:drawableTint="@color/text_secondary" />

                            <TextView
                                android:id="@+id/tvAppointmentDate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_sm"
                                android:layout_weight="1"
                                android:ellipsize="start"
                                android:gravity="end"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_size_body"
                                tools:text="1 Nisan 2026 Çarşamba" />
                        </LinearLayout>

                        <!-- Time -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:drawablePadding="@dimen/spacing_sm"
                                android:text="@string/doctor_examination_time_label"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_size_body_sm"
                                app:drawableStartCompat="@drawable/ic_appointment_clock"
                                app:drawableTint="@color/text_secondary" />

                            <TextView
                                android:id="@+id/tvAppointmentTime"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_sm"
                                android:layout_weight="1"
                                android:ellipsize="start"
                                android:gravity="end"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_size_body"
                                android:textStyle="bold"
                                tools:text="13:40" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="@dimen/spacing_md"
                            android:background="@color/section_divider" />

                        <!-- Hospital -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:drawablePadding="@dimen/spacing_sm"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@string/doctor_examination_hospital_label"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_size_body_sm"
                                app:drawableStartCompat="@drawable/ic_hospital_24"
                                app:drawableTint="@color/text_secondary" />

                            <TextView
                                android:id="@+id/tvHospitalName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_sm"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:gravity="end"
                                android:maxLines="2"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_size_body"
                                tools:text="Ankara Bilkent Şehir Hastanesi" />
                        </LinearLayout>

                        <!-- Branch -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:drawablePadding="@dimen/spacing_sm"
                                android:text="@string/doctor_examination_branch_label"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_size_body_sm"
                                app:drawableStartCompat="@drawable/ic_branch_24"
                                app:drawableTint="@color/text_secondary" />

                            <TextView
                                android:id="@+id/tvBranchName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_sm"
                                android:layout_weight="1"
                                android:background="@drawable/bg_doctor_branch_badge"
                                android:ellipsize="end"
                                android:gravity="end"
                                android:maxLines="2"
                                android:paddingHorizontal="@dimen/badge_padding_horizontal"
                                android:paddingVertical="@dimen/badge_padding_vertical"
                                android:textColor="@color/primary_dark"
                                android:textSize="@dimen/text_size_body_sm"
                                android:textStyle="bold"
                                tools:text="Kardiyoloji" />
                        </LinearLayout>

                        <!-- Doctor -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:drawablePadding="@dimen/spacing_sm"
                                android:text="@string/doctor_examination_doctor_label"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_size_body_sm"
                                app:drawableStartCompat="@drawable/ic_appointment_doctor"
                                app:drawableTint="@color/text_secondary" />

                            <TextView
                                android:id="@+id/tvDoctorName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_sm"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:gravity="end"
                                android:maxLines="2"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_size_body"
                                tools:text="Dr. Mehmet Yıldız" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 2: Examination Note -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/message_card_stroke"
                app:strokeWidth="@dimen/card_stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawablePadding="@dimen/spacing_sm"
                        android:text="@string/doctor_examination_note_label"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_body_lg"
                        android:textStyle="bold"
                        app:drawableStartCompat="@drawable/ic_info_24"
                        app:drawableTint="@color/primary" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MerkeziSaglik.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etExaminationNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top|start"
                            android:hint="@string/doctor_examination_note_hint"
                            android:inputType="textMultiLine"
                            android:maxLines="5"
                            android:minLines="3"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:textSize="@dimen/text_size_body_lg" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 3: Prescription Decision -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/message_card_stroke"
                app:strokeWidth="@dimen/card_stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawablePadding="@dimen/spacing_sm"
                        android:text="@string/doctor_examination_prescription_decision_label"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_body_lg"
                        android:textStyle="bold"
                        app:drawableStartCompat="@drawable/ic_bottom_prescriptions_24"
                        app:drawableTint="@color/primary" />

                    <RadioGroup
                        android:id="@+id/rgPrescriptionDecision"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:orientation="vertical">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbPrescriptionRequiredYes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp"
                            android:paddingStart="@dimen/spacing_sm"
                            android:text="@string/doctor_examination_prescription_yes"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_body_lg" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbPrescriptionRequiredNo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp"
                            android:paddingStart="@dimen/spacing_sm"
                            android:text="@string/doctor_examination_prescription_no"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_body_lg" />
                    </RadioGroup>

                    <!-- Medicine Section (visible when prescription required) -->
                    <LinearLayout
                        android:id="@+id/layoutMedicineSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="@dimen/spacing_lg"
                            android:background="@color/section_divider" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:maxLines="2"
                                android:text="@string/doctor_examination_selected_medicines_title"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_size_body_lg"
                                android:textStyle="bold" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAddMedicine"
                                style="@style/Widget.MerkeziSaglik.Button.Compact"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="0dp"
                                android:text="@string/doctor_examination_add_medicine"
                                android:textAllCaps="false" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvNoMedicineSelected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:background="@drawable/bg_section_card"
                            android:gravity="center"
                            android:padding="@dimen/spacing_lg"
                            android:text="@string/doctor_examination_no_medicine_selected"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_body" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvSelectedMedicines"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:nestedScrollingEnabled="false"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                            tools:itemCount="2"
                            tools:listitem="@layout/item_doctor_selected_medicine" />
                    </LinearLayout>

                    <!-- Doctor Note for Prescription -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:text="@string/doctor_examination_doctor_note_label"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_body_lg"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MerkeziSaglik.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDoctorNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top|start"
                            android:hint="@string/doctor_examination_doctor_note_hint"
                            android:inputType="textMultiLine"
                            android:maxLines="4"
                            android:minLines="2"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:textSize="@dimen/text_size_body_lg" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMarkPatientMissed"
                    style="@style/Widget.MerkeziSaglik.Button.Action.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/action_button_height"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:text="@string/doctor_examination_mark_missed"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCompleteExamination"
                    style="@style/Widget.MerkeziSaglik.Button.Action.Primary"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/action_button_height"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:text="@string/doctor_examination_complete"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
