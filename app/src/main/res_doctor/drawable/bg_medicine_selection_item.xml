<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/primary_surface" />
            <corners android:radius="@dimen/card_corner_radius_sm" />
            <stroke
                android:width="@dimen/card_stroke_width"
                android:color="@color/primary" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/section_header_bg" />
            <corners android:radius="@dimen/card_corner_radius_sm" />
            <stroke
                android:width="@dimen/card_stroke_width"
                android:color="@color/primary_light" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface" />
            <corners android:radius="@dimen/card_corner_radius_sm" />
            <stroke
                android:width="@dimen/card_stroke_width"
                android:color="@color/section_divider" />
        </shape>
    </item>
</selector>
