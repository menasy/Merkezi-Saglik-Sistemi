<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/spacing_sm"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="0dp"
    app:strokeColor="@color/message_card_stroke"
    app:strokeWidth="@dimen/card_stroke_width">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Medicine Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/medicine_header_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/selected_medicine_card_padding"
            android:paddingVertical="@dimen/selected_medicine_header_padding_v">

            <FrameLayout
                android:layout_width="@dimen/icon_size_md"
                android:layout_height="@dimen/icon_size_md"
                android:background="@drawable/bg_medicine_preview_icon_badge">

                <ImageView
                    android:layout_width="@dimen/icon_size_sm"
                    android:layout_height="@dimen/icon_size_sm"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_bottom_prescriptions_24"
                    app:tint="@color/medicine_header_icon" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvMedicineName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_body_lg"
                android:textStyle="bold"
                tools:text="Parol 500 mg Tablet" />
        </LinearLayout>

        <!-- Medicine Details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/selected_medicine_card_padding">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <!-- Dosage -->
                <LinearLayout
                    android:id="@+id/layoutDosage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_medicine_preview_metric"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:paddingVertical="@dimen/spacing_sm">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/medicine_preview_dosage_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_body_sm" />

                    <TextView
                        android:id="@+id/tvMedicineDosage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_body"
                        android:textStyle="bold"
                        tools:text="500 mg" />
                </LinearLayout>

                <!-- Frequency -->
                <LinearLayout
                    android:id="@+id/layoutFrequency"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_medicine_preview_metric"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:paddingVertical="@dimen/spacing_sm">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/medicine_preview_frequency_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_body_sm" />

                    <TextView
                        android:id="@+id/tvMedicineFrequency"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_body"
                        android:textStyle="bold"
                        tools:text="Günde 3 kez" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:id="@+id/layoutUsage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:background="@drawable/bg_medicine_preview_metric"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_md"
                android:paddingVertical="@dimen/spacing_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/medicine_preview_usage_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_body_sm" />

                <TextView
                    android:id="@+id/tvMedicineUsage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_body"
                    android:textStyle="bold"
                    tools:text="Tok karnına 1 tablet" />
            </LinearLayout>

            <!-- Doctor Note (if exists) -->
            <LinearLayout
                android:id="@+id/layoutMedicineNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:background="@drawable/bg_medicine_preview_note"
                android:gravity="top"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_md"
                android:paddingVertical="@dimen/spacing_sm"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="@dimen/icon_size_sm"
                    android:layout_height="@dimen/icon_size_sm"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_info_24"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:id="@+id/tvMedicineNote"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_body_sm"
                    tools:text="Gece yatmadan önce almayın." />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
