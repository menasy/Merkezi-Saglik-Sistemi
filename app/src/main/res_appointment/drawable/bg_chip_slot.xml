<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Disabled state -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/chip_slot_unavailable_bg" />
            <stroke
                android:width="1dp"
                android:color="@color/chip_slot_unavailable_stroke" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    
    <!-- Checked state -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/chip_slot_selected_bg" />
            <stroke
                android:width="2dp"
                android:color="@color/chip_slot_selected_stroke" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    
    <!-- Default available state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/chip_slot_available_bg" />
            <stroke
                android:width="1.5dp"
                android:color="@color/chip_slot_available_stroke" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
