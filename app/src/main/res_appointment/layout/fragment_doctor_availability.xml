<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context="com.menasy.merkezisagliksistemi.ui.patient.appointment.DoctorAvailabilityFragment">

    <!-- Title Row -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutDoctorAvailabilityTitleRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvDoctorAvailabilityTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Doktor Uygun Saatleri"
            android:textAppearance="@style/TextAppearance.MerkeziSaglik.PageTitle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnBackDoctorAvailability"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnBackDoctorAvailability"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_top_back_button"
            android:contentDescription="@string/common_back"
            android:padding="6dp"
            android:src="@drawable/ic_arrow_back_24"
            app:tint="@color/primary_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Doctor Info Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDoctorInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="14dp"
        app:cardElevation="1dp"
        app:strokeColor="@color/primary_light"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutDoctorAvailabilityTitleRow">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvDoctorName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                tools:text="Uzm. Dr. Ahmet Demir" />

            <TextView
                android:id="@+id/tvHospitalName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/text_secondary"
                tools:text="Ankara Şehir Hastanesi" />

            <TextView
                android:id="@+id/tvBranchName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/text_secondary"
                tools:text="Kardiyoloji" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Day Slots RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDoctorDays"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/cardSelectionFooter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardDoctorInfo"
        tools:listitem="@layout/item_doctor_day_slots" />

    <!-- Selection Footer Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSelectionFooter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/primary_light"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvSelectedSlotLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seçilen Randevu"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/section_label_text"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSelectedSlotValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Henüz seçilmedi"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinueToConfirmation"
                style="@style/Widget.MerkeziSaglik.Button.Medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:enabled="false"
                android:text="Randevu Onayına Geç" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
